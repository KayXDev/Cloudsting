# GitHub-safe example environment for local development.
# Copy to .env and replace placeholder values before running the app.

# App / runtime
NODE_ENV="development"
APP_URL="http://localhost:3000"

# Database
# MongoDB replica set is recommended for Prisma with MongoDB.
DATABASE_URL="mongodb://127.0.0.1:27017/kayxhosting?replicaSet=rs0"

# Cache / rate limiting
REDIS_URL="redis://127.0.0.1:6379"

# Minecraft public addressing (homepage stats / public pings)
# The app will ping: <pterodactylIdentifier><MC_PUBLIC_HOST_SUFFIX>:<MC_PUBLIC_DEFAULT_PORT>
MC_PUBLIC_HOST_SUFFIX=".mcsh.io"
MC_PUBLIC_DEFAULT_PORT=25565

# Auth
JWT_ACCESS_SECRET="CHANGE_ME_TO_A_LONG_RANDOM_STRING_AT_LEAST_32_CHARS"
JWT_REFRESH_SECRET="CHANGE_ME_TO_A_LONG_RANDOM_STRING_AT_LEAST_32_CHARS"
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000

# Stripe (optional)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# PayPal (optional)
PAYPAL_CLIENT_ID=""
PAYPAL_CLIENT_SECRET=""
PAYPAL_WEBHOOK_ID=""
PAYPAL_ENV="sandbox"

# SMTP / email (optional)
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Cloudsting <no-reply@example.com>"
SUPPORT_INBOX="support@example.com"

# Pterodactyl
# Public panel URL used for dashboard links/buttons.
NEXT_PUBLIC_PTERO_PANEL_URL="https://panel.example.com"

# Application API base URL.
PTERO_URL="https://panel.example.com"
PTERO_APPLICATION_API_KEY=""

# Client API key used for start/stop/restart/kill actions.
# Create it in the panel as a client key (usually starts with ptlc_...).
PTERO_CLIENT_API_KEY=""
PTERO_AUTO_CREATE_USER=false

# Provisioning defaults
PTERO_DEFAULT_EGG_ID=1
PTERO_DEFAULT_DOCKER_IMAGE="ghcr.io/pterodactyl/yolks:java_17"
PTERO_DEFAULT_STARTUP="java -Xms128M -Xmx{{SERVER_MEMORY}}M -jar server.jar"
# JSON string example: {"SERVER_JARFILE":"server.jar","EULA":"true","VANILLA_VERSION":"latest"}
PTERO_DEFAULT_ENV='{"SERVER_JARFILE":"server.jar","EULA":"true","VANILLA_VERSION":"latest"}'

# Optional seed admin used by prisma/seed.js and prisma/seed.ts
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="CHANGE_ME_ADMIN_PASSWORD"

# Paymenter (optional)
# Set PAYMENTER_URL to the panel base URL, not the API path.
PAYMENTER_URL="https://billing.example.com"
PAYMENTER_API_KEY=""
PAYMENTER_CURRENCY_CODE="USD"
# Example: {"starter":{"productId":1,"planId":2},"pro":{"productId":3,"planId":4}}
PAYMENTER_SERVICE_MAPPING=""
